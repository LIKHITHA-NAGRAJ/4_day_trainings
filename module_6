#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n; cin >> n;
    if (n == 0) return 0;
    vector<int> nums(n);
    for(int i = 0; i < n; i++) cin >> nums[i];

    int i = 0;
    for (int j = 1; j < n; j++) {
        if (nums[j] != nums[i]) {
            i++;
            nums[i] = nums[j];
        }
    }
    cout << i + 1; // Number of unique elements
    return 0;
}


