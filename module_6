#include <iostream>
#include <string>
#include <cctype>
using namespace std;

int main() {
    string s;
    getline(cin, s);
    int left = 0, right = s.length() - 1;
    bool valid = true;

    while (left < right) {
        if (!isalnum(s[left])) left++;
        else if (!isalnum(s[right])) right--;
        else {
            if (tolower(s[left++]) != tolower(s[right--])) {
                valid = false;
                break;
            }
        }
    }
    cout << (valid ? "true" : "false");
    return 0;
}




