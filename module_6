#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int main() {
    int n; cin >> n;
    vector<int> height(n);
    for(int i = 0; i < n; i++) cin >> height[i];

    int left = 0, right = n - 1, maxArea = 0;
    while (left < right) {
        int h = min(height[left], height[right]);
        maxArea = max(maxArea, h * (right - left));
        if (height[left] < height[right]) left++;
        else right--;
    }
    cout << maxArea;
    return 0;
}

