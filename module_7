#include <iostream>
#include <string>
#include <algorithm>
using namespace std;

int main() {
    string s; cin >> s;
    int curr = 0, maxD = 0;
    for (char c : s) {
        if (c == '(') {
            curr++;
            maxD = max(maxD, curr);
        } else if (c == ')') curr--;
    }
    cout << maxD;
    return 0;
}









