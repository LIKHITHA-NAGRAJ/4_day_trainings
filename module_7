#include <iostream>
#include <queue>
#include <string>
using namespace std;

int main() {
    queue<string> patientQueue;
    string cmd, name;

    while (cin >> cmd && cmd != "EXIT") {
        if (cmd == "ARRIVE") {
            cin >> name;
            patientQueue.push(name);
        } else if (cmd == "NEXT") {
            if (!patientQueue.empty()) {
                cout << "Treating: " << patientQueue.front() << endl;
                patientQueue.pop_back();
            } else cout << "No patients" << endl;
        }
    }
    return 0;
}


