#include <iostream>
#include <vector>
#include <string>
using namespace std;

int main() {
    vector<string> backStack, forwardStack;
    string curr = "homepage";
    string cmd, url;

    while (cin >> cmd && cmd != "EXIT") {
        if (cmd == "VISIT") {
            cin >> url;
            backStack.push_back(curr);
            curr = url;
            forwardStack.clear();
        } else if (cmd == "BACK") {
            if (!backStack.empty()) {
                forwardStack.push_back(curr);
                curr = backStack.back();
                backStack.pop_back();
            }
        } else if (cmd == "FORWARD") {
            if (!forwardStack.empty()) {
                backStack.push_back(curr);
                curr = forwardStack.back();
                forwardStack.pop_back();
            }
        }
        cout << "Current: " << curr << endl;
    }
    return 0;
}




