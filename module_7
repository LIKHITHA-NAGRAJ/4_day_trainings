#include <iostream>
#include <vector>
#include <string>
using namespace std;

int main() {
    vector<string> textStack;
    string command, word;

    while (cin >> command && command != "EXIT") {
        if (command == "TYPE") {
            cin >> word;
            textStack.push_back(word);
        } else if (command == "UNDO") {
            if (!textStack.empty()) textStack.pop_back();
        } else if (command == "SHOW") {
            if (textStack.empty()) cout << "EMPTY" << endl;
            else cout << textStack.back() << endl;
        }
    }
    return 0;
}

