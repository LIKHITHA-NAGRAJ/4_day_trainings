#include <iostream>
#include <vector>
#include <string>
using namespace std;

bool isBalanced(string s) {
    vector<char> st;
    for (char c : s) {
        if (c == '(' || c == '{' || c == '[') st.push_back(c);
        else {
            if (st.empty()) return false;
            if ((c == ')' && st.back() == '(') || 
                (c == '}' && st.back() == '{') || 
                (c == ']' && st.back() == '[')) st.pop_back();
            else return false;
        }
    }
    return st.empty();
}

int main() {
    string s; cin >> s;
    cout << (isBalanced(s) ? "BALANCED" : "NOT BALANCED");
    return 0;
}


