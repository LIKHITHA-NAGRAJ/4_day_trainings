#include <iostream>
#include <unordered_set>
#include <vector>
using namespace std;

int main() {
    int n, id;
    cin >> n;
    unordered_set<int> uniqueIDs;
    vector<int> result;

    for (int i = 0; i < n; i++) {
        cin >> id;
        if (uniqueIDs.find(id) == uniqueIDs.end()) {
            uniqueIDs.insert(id);
            result.push_back(id);
        }
    }

    for (int val : result) cout << val << " ";
    return 0;
}


