#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n, k; cin >> n >> k;
    vector<int> a(n);
    for(int i=0; i<n; i++) cin >> a[i];
    int l = 0, r = 0, zeros = 0, ans = 0;
    while(r < n) {
        if(a[r] == 0) zeros++;
        while(zeros > k) {
            if(a[l] == 0) zeros--;
            l++;
        }
        ans = max(ans, r - l + 1);
        r++;
    }
    cout << ans; return 0;
}

