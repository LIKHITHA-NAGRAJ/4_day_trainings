#include <iostream>
#include <map>
#include <string>
using namespace std;

int main() {
    int n; cin >> n;
    map<string, int> activity;
    string id;
    for(int i=0; i<n; i++) {
        cin >> id;
        activity[id]++;
    }
    string top; int mx = 0;
    for(auto const& [name, count] : activity) {
        if(count > mx) { mx = count; top = name; }
    }
    cout << "TOP REVIEWER: " << top << " (" << mx << " REVIEWS)";
    return 0;
}

