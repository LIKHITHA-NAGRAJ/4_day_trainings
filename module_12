#include <iostream>
#include <string>
#include <vector>
using namespace std;

int main() {
    string s, p; cin >> s >> p;
    if(s.size() < p.size()) { cout << "NONE"; return 0; }
    vector<int> pFreq(26, 0), sFreq(26, 0), res;
    for(char c : p) pFreq[c-'a']++;
    for(int i=0; i<s.size(); i++) {
        sFreq[s[i]-'a']++;
        if(i >= p.size()) sFreq[s[i-p.size()]-'a']--;
        if(pFreq == sFreq) res.push_back(i - p.size() + 1);
    }
    if(res.empty()) cout << "NONE";
    else for(int x : res) cout << x << " ";
    return 0;
}

