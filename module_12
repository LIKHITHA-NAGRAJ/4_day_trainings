#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n, bookings; cin >> n >> bookings;
    vector<int> seats(n + 1, 0);
    for(int i=0; i<bookings; i++) {
        int first, last, val; cin >> first >> last >> val;
        for(int j=first; j<=last; j++) seats[j-1] += val;
    }
    for(int i=0; i<n; i++) cout << seats[i] << " ";
    return 0;
}

