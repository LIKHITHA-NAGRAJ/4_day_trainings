#include <iostream>
#include <map>
#include <vector>
#include <algorithm>
using namespace std;

int main() {
    int n; cin >> n;
    map<string, int> sales;
    for(int i=0; i<n; i++) {
        string item; int qty; cin >> item >> qty;
        sales[item] += qty;
    }
    vector<pair<int, string>> rank;
    for(auto const& [item, qty] : sales) rank.push_back({qty, item});
    sort(rank.rbegin(), rank.rend());
    for(auto const& p : rank) cout << p.second << ": " << p.first << endl;
    return 0;
}

