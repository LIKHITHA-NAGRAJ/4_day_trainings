#include <iostream>
#include <vector>
#include <set>
using namespace std;

int main() {
    int n; cin >> n;
    set<int> top3;
    for(int i = 0; i < n; i++) {
        int val; cin >> val;
        top3.insert(val);
        if(top3.size() > 3) top3.erase(top3.begin());
    }
    if(top3.size() < 3) {
        auto it = top3.end(); --it;
        cout << *it;
    } else {
        cout << *top3.begin();
    }
    return 0;
}




