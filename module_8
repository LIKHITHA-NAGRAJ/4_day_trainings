#include <vector>
using namespace std;

int main() {
    int n, target;
    cin >> n >> target;
    vector<int> nums(n);
    for(int i = 0; i < n; i++) cin >> nums[i];

    int left = 0, right = n - 1;
    while(left <= right) {
        int mid = left + (right - left) / 2;
        if(nums[mid] == target) {
            cout << mid;
            return 0;
        }
        if(nums[mid] < target) left = mid + 1;
        else right = mid - 1;
    }
    cout << -1;
    return 0;
}




