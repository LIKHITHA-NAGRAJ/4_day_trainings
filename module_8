#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n;
    cin >> n;
    vector<int> ranks(n);
    for(int i = 0; i < n; i++) cin >> ranks[i];

    for(int i = 0; i < n - 1; i++) {
        for(int j = 0; j < n - i - 1; j++) {
            if(ranks[j] > ranks[j+1]) swap(ranks[j], ranks[j+1]);
        }
    }

    for(int x : ranks) cout << x << " ";
    return 0;
}


