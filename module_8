#include <iostream>
using namespace std;

// Mock API
bool isBadVersion(int version, int firstBad) {
    return version >= firstBad;
}

int main() {
    int n, firstBad;
    cin >> n >> firstBad;
    int left = 1, right = n, ans = n;
    while(left <= right) {
        int mid = left + (right - left) / 2;
        if(isBadVersion(mid, firstBad)) {
            ans = mid;
            right = mid - 1;
        } else left = mid + 1;
    }
    cout << ans;
    return 0;
}


