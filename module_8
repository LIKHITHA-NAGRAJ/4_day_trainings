#include <iostream>
using namespace std;

int main() {
    int x;
    cin >> x;
    if (x < 2) { cout << x; return 0; }
    
    long left = 2, right = x / 2, ans;
    while (left <= right) {
        long mid = left + (right - left) / 2;
        long num = mid * mid;
        if (num == x) { cout << mid; return 0; }
        if (num < x) {
            ans = mid;
            left = mid + 1;
        } else right = mid - 1;
    }
    cout << ans;
    return 0;
}



