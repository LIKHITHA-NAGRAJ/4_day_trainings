#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;
    if (n < 0) { cout << "NO"; return 0; }
    
    int original = n, rev = 0;
    while (n > 0) {
        rev = rev * 10 + (n % 10);
        n /= 10;
    }
    if (original == rev) cout << "YES";
    else cout << "NO";
    return 0;
}















