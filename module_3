#include <iostream>
using namespace std;

int main() {
    long long n;
    cin >> n;
    int count = 0;
    if (n == 0) count = 1;
    else {
        n = abs(n);
        while (n > 0) {
            n /= 10;
            count++;
        }
    }
    cout << count;
    return 0;
}


