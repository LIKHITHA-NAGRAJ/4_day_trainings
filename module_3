#include <iostream>
using namespace std;

int main() {
    int n, rev = 0;
    cin >> n;
    bool negative = n < 0;
    n = abs(n);
    while (n > 0) {
        rev = rev * 10 + (n % 10);
        n /= 10;
    }
    cout << (negative ? -rev : rev);
    return 0;
}



