#include <iostream>
#include <map>
#include <vector>
using namespace std;

int main() {
    int n;
    if (!(cin >> n)) return 0;
    
    map<int, int> counts;
    for (int i = 0; i < n; i++) {
        int sku;
        cin >> sku;
        counts[sku]++;
    }

    bool found = false;
    for (auto const& [sku, freq] : counts) {
        if (freq > 1) {
            cout << sku << " " << freq << endl;
            found = true;
        }
    }

    if (!found) cout << "NO DUPLICATES";
    return 0;
}

