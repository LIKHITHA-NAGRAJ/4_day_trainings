#include <iostream>
#include <vector>
#include <iomanip>
#include <algorithm>

using namespace std;

int main() {
    int n, k;
    if (!(cin >> n >> k)) return 0;
    
    vector<int> scores(n);
    for (int i = 0; i < n; i++) cin >> scores[i];

    if (k > n) return 0;

    double currentSum = 0;
    // Calculate initial window
    for (int i = 0; i < k; i++) {
        currentSum += scores[i];
    }

    double maxSum = currentSum;

    // Slide the window
    for (int i = k; i < n; i++) {
        currentSum += scores[i] - scores[i - k];
        maxSum = max(maxSum, currentSum);
    }

    cout << fixed << setprecision(2) << "Max Average Engagement: " << (maxSum / k) << endl;
    return 0;
}

