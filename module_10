#include <iostream>
#include <string>
#include <map>
#include <vector>
#include <algorithm>

using namespace std;

// Comparator to sort by registration count (descending)
bool compareEvents(const pair<string, int>& a, const pair<string, int>& b) {
    if (a.second != b.second) {
        return a.second > b.second; 
    }
    return a.first < b.first; // Sort alphabetically if counts are equal
}

int main() {
    int n;
    cin >> n;
    map<string, int> eventMap;

    for (int i = 0; i < n; i++) {
        string eventName;
        int registrations;
        cin >> eventName >> registrations;
        eventMap[eventName] += registrations;
    }

    // Move to vector for sorting
    vector<pair<string, int>> sortedEvents(eventMap.begin(), eventMap.end());
    sort(sortedEvents.begin(), sortedEvents.end(), compareEvents);

    cout << "--- Event Popularity Rankings ---" << endl;
    for (const auto& entry : sortedEvents) {
        cout << entry.first << ": " << entry.second << " registrations" << endl;
    }

    return 0;
}
