#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int main() {
    int n; cin >> n;
    int maxOnes = 0, currentOnes = 0;
    for (int i = 0; i < n; i++) {
        int val; cin >> val;
        if (val == 1) {
            currentOnes++;
            maxOnes = max(maxOnes, currentOnes);
        } else {
            currentOnes = 0;
        }
    }
    cout << maxOnes;
    return 0;
}

