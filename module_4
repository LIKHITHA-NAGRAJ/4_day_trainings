#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n; cin >> n;
    if (n < 2) { cout << 0; return 0; }
    vector<int> temps(n);
    for (int i = 0; i < n; i++) cin >> temps[i];
    
    int increases = 0;
    for (int i = 1; i < n; i++) {
        if (temps[i] > temps[i-1]) increases++;
    }
    cout << "Days with increase: " << increases;
    return 0;
}


