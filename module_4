#include <iostream>
#include <algorithm>
using namespace std;

int main() {
    int rows, cols; cin >> rows >> cols;
    int maxWealth = 0;
    for (int i = 0; i < rows; i++) {
        int currentWealth = 0;
        for (int j = 0; j < cols; j++) {
            int money; cin >> money;
            currentWealth += money;
        }
        maxWealth = max(maxWealth, currentWealth);
    }
    cout << maxWealth;
    return 0;
}







































































