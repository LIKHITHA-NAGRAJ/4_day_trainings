#include <iostream>
#include <string>
using namespace std;

int main() {
    int age;
    char gender, health; // M/F, G(ood)/P(oor)
    cin >> age >> gender >> health;
    int premium = 0;
    if (age >= 18 && age <= 35 && health == 'G') {
        premium = (gender == 'M') ? 5000 : 4000;
    } else if (age > 35 && age <= 50 && health == 'G') {
        premium = (gender == 'M') ? 8000 : 7000;
    } else {
        premium = 12000; // Default high risk
    }
    cout << "Premium: Rs " << premium;
    return 0;
}


