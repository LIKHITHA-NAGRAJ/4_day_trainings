#include <iostream>
#include <string>
using namespace std;

int main() {
    int age;
    string time; // Matinee or Evening
    cin >> age >> time;
    int price = (time == "Matinee") ? 150 : 250;
    if (age <= 12 || age >= 60) price -= 50; // Discount
    cout << "Ticket Price: Rs " << price;
    return 0;
}



