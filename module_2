#include <iostream>
using namespace std;

int main() {
    double income;
    cin >> income;
    double tax = 0;
    if (income > 1000000) { tax += (income - 1000000) * 0.3; income = 1000000; }
    if (income > 500000) { tax += (income - 500000) * 0.2; income = 500000; }
    if (income > 250000) { tax += (income - 250000) * 0.05; }
    cout << "Annual Tax: Rs " << tax;
    return 0;
}


