#include <iostream>
using namespace std;

int main() {
    double w, h;
    cin >> w >> h;
    double bmi = w / (h * h);
    cout << "BMI: " << bmi << " - ";
    if (bmi < 18.5) cout << "Underweight";
    else if (bmi < 25) cout << "Normal";
    else if (bmi < 30) cout << "Overweight";
    else cout << "Obese";
    return 0;
}












































































































