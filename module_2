#include <iostream>
using namespace std;

int main() {
    int units;
    cin >> units;
    int bill = 0;
    if (units > 500) { bill += (units - 500) * 10; units = 500; }
    if (units > 300) { bill += (units - 300) * 6; units = 300; }
    if (units > 100) { bill += (units - 100) * 4; units = 100; }
    bill += units * 2;
    cout << "Total Bill: Rs " << bill;
    return 0;
}


