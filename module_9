#include <iostream>
#include <string>
#include <iomanip>

using namespace std;

int main() {
    string name;
    double basic;
    cin >> name >> basic;

    double hra = basic * 0.20;
    double da = basic * 0.10;
    double pf = basic * 0.12;
    double gross = basic + hra + da;
    
    // Simple Slab-based Tax logic (Monthly)
    double tax = 0;
    if (gross > 50000) tax = gross * 0.10;
    else if (gross > 30000) tax = gross * 0.05;

    double netPay = gross - pf - tax;

    cout << "--- Salary Slip: " << name << " ---" << endl;
    cout << "Basic: Rs " << basic << endl;
    cout << "HRA: Rs " << hra << endl;
    cout << "DA: Rs " << da << endl;
    cout << "Gross Pay: Rs " << gross << endl;
    cout << "PF Deduction: Rs " << pf << endl;
    cout << "Tax Deduction: Rs " << tax << endl;
    cout << "Net Monthly Salary: Rs " << netPay << endl;

    return 0;
}


