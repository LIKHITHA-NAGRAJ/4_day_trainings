#include <iostream>
#include <string>
#include <vector>
#include <iomanip>

using namespace std;

int main() {
    int n;
    cin >> n;
    
    string highName, lowName;
    double highPct = -1, lowPct = 101;

    cout << "--- Attendance Report ---" << endl;
    for (int i = 0; i < n; i++) {
        string name;
        double attended, total;
        cin >> name >> attended >> total;
        
        double pct = (attended / total) * 100;
        
        if (pct > highPct) { highPct = pct; highName = name; }
        if (pct < lowPct) { lowPct = pct; lowName = name; }

        cout << name << ": " << fixed << setprecision(2) << pct << "% ";
        cout << (pct >= 75.0 ? "[ELIGIBLE]" : "[NOT-ELIGIBLE]") << endl;
    }

    cout << "\nTop Performer: " << highName << " (" << highPct << "%)" << endl;
    cout << "Lowest Attendance: " << lowName << " (" << lowPct << "%)" << endl;
    
    return 0;
}

