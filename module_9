#include <iostream>
using namespace std;

int main() {
    int days;
    cin >> days;
    
    if (days <= 0) {
        cout << "No Fine. Thank you for returning on time!" << endl;
        return 0;
    }

    int fine = 0;
    int tempDays = days;

    // Slab 3: Days beyond 30
    if (tempDays > 30) {
        fine += (tempDays - 30) * 10;
        tempDays = 30;
    }
    // Slab 2: Days 8 to 30
    if (tempDays > 7) {
        fine += (tempDays - 7) * 5;
        tempDays = 7;
    }
    // Slab 1: First 7 days
    fine += tempDays * 2;

    cout << "Overdue Days: " << days << endl;
    cout << "Total Fine Calculated: Rs " << fine << endl;

    return 0;
}





















































