#include <iostream>
#include <string>
#include <map>

using namespace std;

int main() {
    int n;
    cin >> n;
    map<string, double> revenueMap;
    double totalRevenue = 0;

    for (int i = 0; i < n; i++) {
        string tier;
        double amount;
        cin >> tier >> amount;
        revenueMap[tier] += amount;
        totalRevenue += amount;
    }

    cout << "--- Revenue Summary ---" << endl;
    for (auto const& [tier, rev] : revenueMap) {
        cout << tier << ": Rs " << rev << endl;
    }
    cout << "Total Revenue: Rs " << totalRevenue << endl;
    cout << "Average per Tier: Rs " << (totalRevenue / revenueMap.size()) << endl;

    return 0;
}
