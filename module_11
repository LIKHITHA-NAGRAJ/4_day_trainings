#include <iostream>
#include <string>
#include <vector>
#include <iomanip>

using namespace std;

int main() {
    int n;
    cin >> n;
    double subtotal = 0;

    for (int i = 0; i < n; i++) {
        string category;
        double price;
        cin >> category >> price;

        double discount = 0;
        if (category == "Electronics") discount = 0.10;
        else if (category == "Books") discount = 0.20;
        else if (category == "Clothing") discount = 0.15;
        
        subtotal += price * (1 - discount);
    }

    if (subtotal > 10000) {
        subtotal *= 0.95; // Additional 5% cart-level discount
    }

    cout << fixed << setprecision(2) << "FINAL BILL: " << subtotal << endl;
    return 0;
}


