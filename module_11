#include <iostream>
#include <vector>
#include <algorithm>

using namespace std;

int main() {
    int taskCount, clusterCount;
    cin >> taskCount >> clusterCount;

    vector<int> tasks(taskCount);
    vector<int> clusters(clusterCount, 0); // Stores total load of each cluster

    for (int i = 0; i < taskCount; i++) cin >> tasks[i];

    for (int i = 0; i < taskCount; i++) {
        // Find cluster with minimum load
        int minIdx = 0;
        for (int j = 1; j < clusterCount; j++) {
            if (clusters[j] < clusters[minIdx]) minIdx = j;
        }
        clusters[minIdx] += tasks[i];
    }

    for (int i = 0; i < clusterCount; i++) {
        cout << "Cluster " << i + 1 << " Load: " << clusters[i] << endl;
    }

    return 0;
}

