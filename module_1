#include <iostream>
using namespace std;
int main() {
    int a, b; char op;
    if (!(cin >> a >> b >> op)) return 0;
    if (op == '/' && b == 0) cout << "ERROR: DIVIDE BY ZERO";
    else if (op == '+') cout << a + b;
    else if (op == '-') cout << a - b;
    else if (op == '*') cout << a * b;
    else if (op == '/') cout << a / b;
    return 0;
}

