#include <iostream>
#include <vector>
using namespace std;

int main() {
    int votes[] = {0, 0, 0, 0, 0, 0}; // Index 1-5 for candidates
    int totalVotes, v, valid = 0, invalid = 0;
    cin >> totalVotes;

    for (int i = 0; i < totalVotes; i++) {
        cin >> v;
        if (v >= 1 && v <= 5) {
            votes[v]++;
            valid++;
        } else {
            invalid++;
        }
    }

    int winner = 1;
    for (int i = 2; i <= 5; i++) {
        if (votes[i] > votes[winner]) winner = i;
    }

    cout << "Winner: Candidate " << winner << endl;
    cout << "Valid Votes: " << valid << endl;
    cout << "Invalid Votes: " << invalid << endl;
    return 0;
}

