#include <iostream>
using namespace std;

int main() {
    long long n;
    cin >> n;
    int sum = 0;
    if (n == 0) sum = 0;
    while (n > 0) {
        sum += n % 10;
        n /= 10;
    }
    cout << sum;
    return 0;
}

