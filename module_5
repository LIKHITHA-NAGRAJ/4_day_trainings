#include <iostream>
#include <vector>
#include <map>
#include <algorithm>
using namespace std;

int main() {
    int n; cin >> n;
    vector<int> nums(n);
    map<int, int> freq;
    for (int i = 0; i < n; i++) {
        cin >> nums[i];
        freq[nums[i]]++;
    }

    sort(nums.begin(), nums.end(), [&](int a, int b) {
        if (freq[a] != freq[b]) return freq[a] > freq[b];
        return a < b; // Sort by value if frequencies match
    });

    for (int x : nums) cout << x << " ";
    return 0;
}



