#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n; cin >> n;
    vector<int> nums(n);
    int countMap[101] = {0}; // Constraint: nums[i] <= 100
    for (int i = 0; i < n; i++) {
        cin >> nums[i];
        countMap[nums[i]]++;
    }

    int smaller[101] = {0};
    int runningSum = 0;
    for (int i = 0; i <= 100; i++) {
        smaller[i] = runningSum;
        runningSum += countMap[i];
    }

    for (int x : nums) cout << smaller[x] << " ";
    return 0;
}

