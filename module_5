#include <iostream>
#include <map>
using namespace std;

int main() {
    int n; cin >> n;
    map<int, int> idCounts;
    for (int i = 0; i < n; i++) {
        int id; cin >> id;
        idCounts[id]++;
    }
    
    cout << "Duplicates: ";
    for (auto const& [id, count] : idCounts) {
        if (count > 1) cout << id << " ";
    }
    return 0;
}




