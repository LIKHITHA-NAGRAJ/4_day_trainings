#include <iostream>
using namespace std;

int main() {
    int n; cin >> n;
    int evenCount = 0;
    for (int i = 0; i < n; i++) {
        int num; cin >> num;
        int digits = 0;
        while (num > 0) {
            num /= 10;
            digits++;
        }
        if (digits % 2 == 0) evenCount++;
    }
    cout << evenCount;
    return 0;
}

































































