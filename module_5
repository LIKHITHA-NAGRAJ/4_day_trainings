#include <vector>
using namespace std;

int main() {
    int n; cin >> n;
    int singleNum = 0;
    for (int i = 0; i < n; i++) {
        int val; cin >> val;
        singleNum ^= val; // XOR cancels out pairs: x ^ x = 0
    }
    cout << singleNum;
    return 0;
}



