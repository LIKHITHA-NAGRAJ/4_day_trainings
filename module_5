#include <iostream>
#include <unordered_set>
using namespace std;

int main() {
    int n; cin >> n;
    unordered_set<int> seen;
    int totalSum = 0;
    for (int i = 0; i < n; i++) {
        int val; cin >> val;
        if (seen.find(val) == seen.end()) {
            totalSum += val;
            seen.insert(val);
        }
    }
    cout << totalSum;
    return 0;
}


