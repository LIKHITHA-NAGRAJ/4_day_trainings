#include <iostream>
#include <string>
#include <vector>
using namespace std;

int main() {
    string s;
    getline(cin, s);
    int freq[256] = {0}; // Frequency array for ASCII

    for (char c : s) {
        freq[(int)c]++;
    }

    for (int i = 0; i < 256; i++) {
        if (freq[i] > 0) {
            cout << (char)i << " " << freq[i] << endl;
        }
    }
    return 0;
}


